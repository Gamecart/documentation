{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Gamecart Docs",
  "colors": {
    "primary": "#b355fe",
    "light": "#c77dff",
    "dark": "#6b1fa8"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": [
      {
        "group": "Getting started",
        "pages": [
          "index",
          "quickstart"
        ]
      },
      {
        "group": "Tutorials",
        "pages": [
          "tutorials/overview"
        ]
      },
      {
        "group": "API reference",
        "pages": [
          "api-reference/overview"
        ]
      },
      {
        "group": "Webhooks",
        "pages": [
          "webhooks/overview"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://gamecart.gg",
          "icon": "globe"
        },
        {
          "anchor": "Community",
          "href": "https://discord.gg/gamecart",
          "icon": "comments"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://discord.gg/gamecart"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dash.gamecart.gg"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
