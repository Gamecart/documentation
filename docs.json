{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Gamecart Docs",
  "colors": {
    "primary": "#b355fe",
    "light": "#c77dff",
    "dark": "#6b1fa8"
  },
  "appearance": {
    "default": "dark"
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#ffffff",
      "dark": "#050607"
    }
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "dark"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          }
        ]
      },
      {
        "tab": "Tutorials",
        "icon": "graduation-cap",
        "groups": [
          {
            "group": "Tutorials",
            "pages": [
              "tutorials/overview"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "icon": "code-2",
        "groups": [
          {
            "group": "API reference",
            "pages": [
              "api-reference/overview"
            ]
          }
        ]
      },
      {
        "tab": "Webhooks",
        "icon": "radio-tower",
        "groups": [
          {
            "group": "Webhooks",
            "pages": [
              "webhooks/overview"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://gamecart.gg",
          "icon": "globe"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/gamecart",
          "icon": "message-circle"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://gamecart.gg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://discord.gg/gamecart"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dash.gamecart.gg"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
